# Copy to .env, set BOT_TOKEN, then bring up the whole stack with: docker compose up
# Telegram bot token from @BotFather (required to actually run the bot).
BOT_TOKEN=

# Hostnames the app uses inside docker-compose. The defaults already match the service names,
# so you normally do not need to set these.
# DB_HOST=postgres
# REDIS_HOST=redis

# Admin panel (optional). Leave unset for a bot-only deploy. When enabled, the app serves the panel on :8080.
# ADMIN_PANEL_ENABLED=true
# ADMIN_PANEL_ADMINS=123456789          # comma-separated Telegram user ids allowed to sign in
# VITE_BOT_USERNAME=YourBot             # build-time: compiled into the panel; rebuild the image to change.
#                                       # The Telegram login widget also needs a public domain (BotFather /setdomain).
